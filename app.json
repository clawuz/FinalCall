{
  "expo": {
    "name": "Final Call",
    "slug": "notifawards",
    "scheme": "notifawards",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/all/icons/icon-1024.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/all/splash/splash-iphone-1290x2796.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.notifawards.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Ödül başvuru tarihlerini takvimine eklemek için takvim erişimi gerekiyor.",
        "NSUserNotificationUsageDescription": "Ödül başvuru son tarihleri için bildirim gönderebilmek için izin gerekiyor.",
        "BGTaskSchedulerPermittedIdentifiers": [
          "notifawards-background-fetch"
        ],
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.notifawards.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/all/icons/icon-432.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/all/icons/icon-192.png",
          "color": "#B47AFF"
        }
      ],
      "expo-calendar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25d4e23c-1b4d-4fd4-8d67-4298d3fc3bbb"
      }
    },
    "owner": "kilavuzo"
  }
}
